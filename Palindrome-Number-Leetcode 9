// BRUTE FORCE APPROACH
** int to string => String s = String.valueOf(x);
class Solution {
    public boolean isPalindrome(int x) {
        String s = String.valueOf(x);
        int left=0,right = s.length()-1;
        while(left<right){
            if(s.charAt(left) != s.charAt(right)){
                return false;
            }
            left++;
            right--;
        }
        return true;
    }
}

TC = O(n/2) +O(n) = O(n) // n here is no. of digits in integer
SC = O(n) = string will store n number of digits

// OPTIMISE
class Solution {
    public boolean isPalindrome(int x) {
        if(x < 0) return false;  // negative number will never be palindrome
        int n=x;
        int ans = 0;
        while(n != 0){
            int r = n%10;
            ans = ans*10+r;
            n=n/10;
        }
        return (ans == x);
    }
}
TC = O(n) // n= no. of digits
yahan 10 se baar- baar divide ho raha hai to, d= log (base10) x
SC = O(1)
